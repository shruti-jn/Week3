# ─────────────────────────────────────────────────────────────────────────────
# LegacyLens Frontend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# NEVER commit .env.local to git — it contains real secrets.
# .env.local is in .gitignore — this template (.env.example) is safe to commit.
#
# For production (Vercel): add these in Vercel's Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ─────────────────────────────────────────────────────────────
# The NEXT_PUBLIC_ prefix makes this variable accessible in the browser.
# Without it, Next.js only allows the variable in server-side code.
#
# Local dev: http://localhost:8000  (backend running via docker compose or locally)
# Production: https://your-backend.up.railway.app  (Railway backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Codebase display metadata (shown in search UI) ────────────────────────────
# Human-readable codebase name users see above the query box.
NEXT_PUBLIC_CODEBASE_LABEL=OpenCOBOL Contrib
# Backend Pinecone index this frontend points to.
NEXT_PUBLIC_CODEBASE_INDEX=legacylens

# ── NextAuth.js ─────────────────────────────────────────────────────────────────
# NEXTAUTH_URL must match the URL where the app is actually running.
# NextAuth uses it to construct OAuth callback URLs.
#
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app  (your Vercel deployment URL)
NEXTAUTH_URL=http://localhost:3000

# Secret used to sign and encrypt NextAuth session cookies and JWTs.
# CRITICAL: Must be the same value as NEXTAUTH_SECRET in the backend .env file.
# The backend validates tokens signed with this secret — a mismatch breaks auth.
#
# Generate a secure random value with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ── GitHub OAuth App ─────────────────────────────────────────────────────────────
# Create a GitHub OAuth App at: https://github.com/settings/developers
#
# Callback URL for local dev:  http://localhost:3000/api/auth/callback/github
# Callback URL for production: https://your-app.vercel.app/api/auth/callback/github
#
# Note: You need separate OAuth Apps (or multiple callback URLs) for dev and prod.
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
