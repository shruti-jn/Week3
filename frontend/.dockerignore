# ─────────────────────────────────────────────────────────────────────────────
# Frontend Docker ignore file
# ─────────────────────────────────────────────────────────────────────────────
# Excludes files from the Docker build context (./frontend/ directory).
# These files are either generated by the build process, contain secrets,
# or are development artifacts that don't belong in the container.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node.js build artifacts ────────────────────────────────────────────────────
# The container installs its own node_modules via npm ci.
# Never copy local node_modules — they're tied to your OS/architecture.
node_modules/

# Next.js build output — regenerated by "npm run build" or "next dev".
.next/

# ── Secrets ───────────────────────────────────────────────────────────────────
# CRITICAL: Never bake .env files into Docker images.
# Secrets come from docker-compose env_file or Railway/Vercel variables.
.env.local
.env.*.local
!.env.example

# ── Test artifacts ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── macOS system files ────────────────────────────────────────────────────────
.DS_Store

# ── IDE config ────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
