# ─────────────────────────────────────────────────────────────────────────────
# LegacyLens Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to git — it contains real secrets.
# .env is in .gitignore — this template (.env.example) is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get from: platform.openai.com/api-keys
# Used for: answer generation (gpt-4o-mini)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Voyage AI ─────────────────────────────────────────────────────────────────
# Get from: https://www.voyageai.com/
# Used for: code embeddings (voyage-code-2)
VOYAGE_API_KEY=pk-live-your-voyage-api-key-here

# ── Pinecone ──────────────────────────────────────────────────────────────────
# Get from: console.pinecone.io
# Used for: storing and searching COBOL code embeddings
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=legacylens

# ── Auth (GitHub OAuth) ────────────────────────────────────────────────────────
# Create a GitHub OAuth App at: github.com/settings/developers
# Callback URL for dev: http://localhost:3000/api/auth/callback/github
# Callback URL for prod: https://your-vercel-domain.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# NextAuth secret — used to sign JWT tokens
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-32-char-secret-here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend URL(s) allowed to call this API
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app
ALLOWED_ORIGINS=["http://localhost:3000"]

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=20

# ── Retrieval Tuning ──────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
SIMILARITY_THRESHOLD=0.75

# ── Langfuse Observability (optional) ─────────────────────────────────────────
# Get from: cloud.langfuse.com → Settings → API Keys
# Leave empty (or omit) to run without tracing — the app works fine without it.
# When set, every query is traced with step-wise latency (embed/retrieve/rerank/LLM)
# and similarity metrics visible in the Langfuse dashboard.
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # override for self-hosted or regional instances (e.g. https://us.cloud.langfuse.com)
